  {
    "title": "Rice Cooker",
    "description": "Rice cooker kapasitas 1.8L",
    "price": 350000,
    "linkProduct": "https://tokopedia.com/product/...",
    "thumbnail": "https://res.cloudinary.com/example/kado.jpg"
  }
}

