docs {
  # Update Content

  Update konten undangan. Semua field opsional.

  | Field           | Type   | Description                        |
  |-----------------|--------|------------------------------------|
  | title           | string | Judul undangan                     |
  | nameMale        | string | Nama lengkap mempelai pria         |
  | nameFemale      | string | Nama lengkap mempelai wanita       |
  | fatherMale      | string | Nama ayah mempelai pria            |
  | motherMale      | string | Nama ibu mempelai pria             |
  | fatherFemale    | string | Nama ayah mempelai wanita          |
  | motherFemale    | string | Nama ibu mempelai wanita           |
  | maleNo          | string | Anak ke-N mempelai pria            |
  | femaleNo        | string | Anak ke-N mempelai wanita          |
  | dateWedding     | string | Tanggal pernikahan (ISO date)      |
  | akadTime        | string | Waktu akad                         |
  | akadPlace       | string | Tempat akad                        |
  | resepsiTime     | string | Waktu resepsi                      |
  | resepsiPlace    | string | Tempat resepsi                     |
  | gmaps           | string | Link Google Maps                   |
  | streamLink      | string | Link live streaming                |
  | religionVersion | string | Versi agama                        |
  | imgBg           | string | URL background (Cloudinary)        |
  | imgMale         | string | URL foto mempelai pria             |
  | imgFemale       | string | URL foto mempelai wanita           |
  | imgThumbnail    | string | URL thumbnail                      |
  | music           | string | URL musik (Cloudinary)             |
  | isCovid         | number | 0 = tidak, 1 = ada protokol covid  |
}
